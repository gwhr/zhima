generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum WorkspaceStatus {
  DRAFT
  GENERATING
  READY
  EXPIRED
}

enum PlanType {
  BASIC
  STANDARD
  PREMIUM
}

enum OrderStatus {
  PENDING
  PAID
  REFUNDED
  EXPIRED
}

enum AiTaskType {
  TOPIC
  EVALUATE
  CODE_GEN
  THESIS
  CHART
  MODIFY_SIMPLE
  MODIFY_COMPLEX
}

enum ChatRole {
  USER
  ASSISTANT
  SYSTEM
}

enum FileType {
  CODE
  THESIS
  CHART
  CONFIG
}

enum NotificationType {
  GENERATE_DONE
  QUOTA_WARNING
  EXPIRY_WARNING
  SYSTEM
}

enum AnnouncementLevel {
  INFO
  WARNING
  MAINTENANCE
}

enum JobType {
  CODE_GEN
  THESIS_GEN
  CHART_RENDER
  PREVIEW
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model User {
  id        String   @id @default(cuid())
  phone     String?  @unique
  email     String?  @unique
  password  String
  name      String?
  avatar    String?
  role      Role     @default(USER)
  tokenBudgetOverride Int?
  taskConcurrencyLimitOverride Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaces    Workspace[]
  orders        Order[]
  quotas        UserQuota[]
  aiUsageLogs   AiUsageLog[]
  notifications Notification[]
  inviteCodes   InviteCode[]
  thesisTemplates ThesisTemplate[] @relation("TemplateCreator")
  announcements   Announcement[]   @relation("AnnouncementCreator")
  adminAuditLogs  AdminAuditLog[]  @relation("AdminAuditActor")

  @@index([email])
  @@index([phone])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  adminUserId String?
  action      String
  module      String?
  targetType  String?
  targetId    String?
  summary     String?
  before      Json?
  after       Json?
  metadata    Json?
  createdAt   DateTime @default(now())

  adminUser User? @relation("AdminAuditActor", fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([adminUserId])
  @@index([action])
  @@index([module])
  @@index([createdAt])
}

model Workspace {
  id           String          @id @default(cuid())
  userId       String
  name         String
  topic        String
  techStack    Json            @default("{}")
  requirements Json            @default("[]")
  status       WorkspaceStatus @default(DRAFT)
  expiresAt    DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders       Order[]
  quotas       UserQuota[]
  aiUsageLogs  AiUsageLog[]
  chatMessages ChatMessage[]
  files        WorkspaceFile[]
  taskJobs     TaskJob[]

  @@index([userId])
  @@index([status])
}

model Order {
  id             String      @id @default(cuid())
  userId         String
  workspaceId    String?
  planType       PlanType
  amount         Decimal     @db.Decimal(10, 2)
  status         OrderStatus @default(PENDING)
  paymentChannel String?
  tradeNo        String?     @unique
  paidAt         DateTime?
  createdAt      DateTime    @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
}

model UserQuota {
  id           String   @id @default(cuid())
  userId       String
  workspaceId  String
  planType     PlanType
  opusBudget   Decimal  @default(0) @db.Decimal(10, 2)
  opusUsed     Decimal  @default(0) @db.Decimal(10, 2)
  modifyLimit  Int      @default(0)
  modifyUsed   Int      @default(0)
  previewLimit Int      @default(0)
  previewUsed  Int      @default(0)

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([userId])
}

model AiUsageLog {
  id           String     @id @default(cuid())
  userId       String
  workspaceId  String
  taskType     AiTaskType
  model        String
  inputTokens  Int
  outputTokens Int
  costYuan     Decimal    @db.Decimal(10, 6)
  durationMs   Int
  createdAt    DateTime   @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workspaceId])
  @@index([createdAt])
}

model ChatMessage {
  id          String   @id @default(cuid())
  workspaceId String
  role        ChatRole
  content     String   @db.Text
  metadata    Json?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
}

model WorkspaceFile {
  id          String   @id @default(cuid())
  workspaceId String
  path        String
  type        FileType
  storageKey  String
  size        Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, path])
  @@index([workspaceId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  content   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

model InviteCode {
  id          String   @id @default(cuid())
  userId      String
  code        String   @unique
  usedCount   Int      @default(0)
  rewardTotal Decimal  @default(0) @db.Decimal(10, 2)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TaskJob {
  id          String    @id @default(cuid())
  workspaceId String
  type        JobType
  status      JobStatus @default(PENDING)
  progress    Int       @default(0)
  result      Json?
  error       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([status])
}

model SystemConfig {
  key       String   @id
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ThesisTemplate {
  id          String   @id @default(cuid())
  name        String
  version     String?
  path        String   @unique
  storageKey  String
  size        Int
  isActive    Boolean  @default(false)
  note        String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User? @relation("TemplateCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([isActive])
  @@index([createdAt])
}

model Announcement {
  id          String            @id @default(cuid())
  title       String
  content     String            @db.Text
  level       AnnouncementLevel @default(INFO)
  isPublished Boolean           @default(true)
  createdById String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  createdBy User? @relation("AnnouncementCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([isPublished, createdAt])
}
