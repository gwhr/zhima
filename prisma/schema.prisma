generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum WorkspaceStatus {
  DRAFT
  GENERATING
  READY
  EXPIRED
}

enum PlanType {
  BASIC
  STANDARD
  PREMIUM
}

enum OrderStatus {
  PENDING
  PAID
  REFUNDED
  EXPIRED
}

enum AiTaskType {
  TOPIC
  EVALUATE
  CODE_GEN
  THESIS
  CHART
  MODIFY_SIMPLE
  MODIFY_COMPLEX
}

enum ChatRole {
  USER
  ASSISTANT
  SYSTEM
}

enum FileType {
  CODE
  THESIS
  CHART
  CONFIG
}

enum NotificationType {
  GENERATE_DONE
  QUOTA_WARNING
  EXPIRY_WARNING
  SYSTEM
}

enum AnnouncementLevel {
  INFO
  WARNING
  MAINTENANCE
}

enum JobType {
  CODE_GEN
  THESIS_GEN
  CHART_RENDER
  PREVIEW
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum TokenLedgerType {
  INIT_GRANT
  RECHARGE
  FREEZE
  SETTLE
  REFUND
  MANUAL_ADJUST
  ROLLBACK
}

enum TokenReservationStatus {
  ACTIVE
  SETTLED
  RELEASED
}

enum TaskTokenSettlementStatus {
  NONE
  FROZEN
  SETTLED
  REFUNDED
}

enum FeedbackStatus {
  OPEN
  RESOLVED
}

model User {
  id        String   @id @default(cuid())
  phone     String?  @unique
  email     String?  @unique
  password  String
  name      String?
  avatar    String?
  role      Role     @default(USER)
  tokenBudgetOverride Int?
  taskConcurrencyLimitOverride Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaces    Workspace[]
  orders        Order[]
  quotas        UserQuota[]
  aiUsageLogs   AiUsageLog[]
  notifications Notification[]
  inviteCodes   InviteCode[]
  feedbacks     UserFeedback[] @relation("FeedbackAuthor")
  resolvedFeedbacks UserFeedback[] @relation("FeedbackResolver")
  thesisTemplates ThesisTemplate[] @relation("TemplateCreator")
  announcements   Announcement[]   @relation("AnnouncementCreator")
  adminAuditLogs  AdminAuditLog[]  @relation("AdminAuditActor")
  tokenWallet     UserTokenWallet?
  tokenReservations TokenReservation[]
  tokenLedgers    TokenLedger[]

  @@index([email])
  @@index([phone])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  adminUserId String?
  action      String
  module      String?
  targetType  String?
  targetId    String?
  summary     String?
  before      Json?
  after       Json?
  metadata    Json?
  createdAt   DateTime @default(now())

  adminUser User? @relation("AdminAuditActor", fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([adminUserId])
  @@index([action])
  @@index([module])
  @@index([createdAt])
}

model Workspace {
  id           String          @id @default(cuid())
  userId       String
  name         String
  topic        String
  techStack    Json            @default("{}")
  requirements Json            @default("[]")
  status       WorkspaceStatus @default(DRAFT)
  expiresAt    DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders       Order[]
  quotas       UserQuota[]
  aiUsageLogs  AiUsageLog[]
  chatMessages ChatMessage[]
  files        WorkspaceFile[]
  taskJobs     TaskJob[]
  tokenReservations TokenReservation[]
  tokenLedgers TokenLedger[]

  @@index([userId])
  @@index([status])
}

model Order {
  id             String      @id @default(cuid())
  userId         String
  workspaceId    String?
  planType       PlanType
  amount         Decimal     @db.Decimal(10, 2)
  status         OrderStatus @default(PENDING)
  paymentChannel String?
  tradeNo        String?     @unique
  paidAt         DateTime?
  createdAt      DateTime    @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
}

model UserQuota {
  id           String   @id @default(cuid())
  userId       String
  workspaceId  String
  planType     PlanType
  opusBudget   Decimal  @default(0) @db.Decimal(10, 2)
  opusUsed     Decimal  @default(0) @db.Decimal(10, 2)
  modifyLimit  Int      @default(0)
  modifyUsed   Int      @default(0)
  previewLimit Int      @default(0)
  previewUsed  Int      @default(0)

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([userId])
}

model AiUsageLog {
  id           String     @id @default(cuid())
  userId       String
  workspaceId  String
  taskJobId    String?
  taskType     AiTaskType
  model        String
  inputTokens  Int
  outputTokens Int
  cacheHitTokens Int      @default(0)
  costYuan     Decimal    @db.Decimal(10, 6)
  billedPoints Int        @default(0)
  pointRate    Int        @default(1000)
  billingMultiplier Decimal @default(1) @db.Decimal(8, 4)
  durationMs   Int
  createdAt    DateTime   @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  taskJob   TaskJob?  @relation(fields: [taskJobId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([workspaceId])
  @@index([taskJobId])
  @@index([createdAt])
}

model ChatMessage {
  id          String   @id @default(cuid())
  workspaceId String
  role        ChatRole
  content     String   @db.Text
  metadata    Json?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
}

model WorkspaceFile {
  id          String   @id @default(cuid())
  workspaceId String
  path        String
  type        FileType
  storageKey  String
  size        Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, path])
  @@index([workspaceId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  content   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

model InviteCode {
  id          String   @id @default(cuid())
  userId      String
  code        String   @unique
  usedCount   Int      @default(0)
  rewardTotal Decimal  @default(0) @db.Decimal(10, 2)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TaskJob {
  id          String    @id @default(cuid())
  workspaceId String
  type        JobType
  status      JobStatus @default(PENDING)
  progress    Int       @default(0)
  tokenReservedPoints Int @default(0)
  tokenSettledPoints Int @default(0)
  tokenCostYuan Decimal @default(0) @db.Decimal(12, 6)
  tokenSettlementStatus TaskTokenSettlementStatus @default(NONE)
  tokenSettledAt DateTime?
  result      Json?
  error       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace         Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tokenReservation  TokenReservation?
  tokenLedgers      TokenLedger[]
  aiUsageLogs       AiUsageLog[]

  @@index([workspaceId])
  @@index([status])
}

model UserTokenWallet {
  id             String   @id @default(cuid())
  userId         String   @unique
  totalPoints    Int      @default(0)
  availablePoints Int     @default(0)
  frozenPoints   Int      @default(0)
  usedPoints     Int      @default(0)
  dailyUsedPoints Int     @default(0)
  dailyUsageDate String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([dailyUsageDate])
}

model TokenReservation {
  id            String                 @id @default(cuid())
  userId        String
  workspaceId   String?
  taskJobId     String?                @unique
  source        String
  reservedPoints Int
  settledPoints Int                    @default(0)
  status        TokenReservationStatus @default(ACTIVE)
  metadata      Json?
  settledAt     DateTime?
  releasedAt    DateTime?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace    Workspace?  @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  taskJob      TaskJob?    @relation(fields: [taskJobId], references: [id], onDelete: SetNull)
  tokenLedgers TokenLedger[]

  @@index([userId, status, createdAt])
  @@index([workspaceId, createdAt])
}

model TokenLedger {
  id                   String          @id @default(cuid())
  userId               String
  workspaceId          String?
  taskJobId            String?
  reservationId        String?
  type                 TokenLedgerType
  deltaAvailablePoints Int             @default(0)
  deltaFrozenPoints    Int             @default(0)
  deltaUsedPoints      Int             @default(0)
  availableAfter       Int             @default(0)
  frozenAfter          Int             @default(0)
  usedAfter            Int             @default(0)
  billedPoints         Int             @default(0)
  pointRate            Int             @default(1000)
  billingMultiplier    Decimal         @default(1) @db.Decimal(8, 4)
  model                String?
  taskType             AiTaskType?
  inputTokens          Int             @default(0)
  outputTokens         Int             @default(0)
  cacheHitTokens       Int             @default(0)
  costYuan             Decimal         @default(0) @db.Decimal(12, 6)
  description          String?
  metadata             Json?
  createdAt            DateTime        @default(now())

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace?        @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  taskJob     TaskJob?          @relation(fields: [taskJobId], references: [id], onDelete: SetNull)
  reservation TokenReservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([workspaceId, createdAt])
  @@index([taskJobId])
  @@index([reservationId])
  @@index([type, createdAt])
}

model SystemConfig {
  key       String   @id
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ThesisTemplate {
  id          String   @id @default(cuid())
  name        String
  version     String?
  path        String   @unique
  storageKey  String
  size        Int
  isActive    Boolean  @default(false)
  note        String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User? @relation("TemplateCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([isActive])
  @@index([createdAt])
}

model Announcement {
  id          String            @id @default(cuid())
  title       String
  content     String            @db.Text
  level       AnnouncementLevel @default(INFO)
  isPublished Boolean           @default(true)
  createdById String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  createdBy User? @relation("AnnouncementCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([isPublished, createdAt])
}

model UserFeedback {
  id           String         @id @default(cuid())
  userId       String
  content      String         @db.Text
  contact      String?
  pagePath     String?
  imageKeys    String[]       @default([])
  status       FeedbackStatus @default(OPEN)
  adminNote    String?        @db.Text
  resolvedAt   DateTime?
  resolvedById String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user       User  @relation("FeedbackAuthor", fields: [userId], references: [id], onDelete: Cascade)
  resolvedBy User? @relation("FeedbackResolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([status, createdAt])
}
