# Database
DATABASE_URL=postgresql://zhima:zhima_dev@localhost:5433/zhima

# Redis
REDIS_URL=redis://localhost:6379

# NextAuth
NEXTAUTH_SECRET=your-secret-here-change-in-production
NEXTAUTH_URL=http://localhost:3000
# Optional: dedicated secret for encrypting admin-saved model keys
# If empty, system falls back to NEXTAUTH_SECRET
CONFIG_ENCRYPTION_SECRET=

# Zhipu GLM (required)
ZHIPU_API_KEY=your-zhipu-api-key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Optional AI providers
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Worker fixed model strategy (no frontend model dropdown)
CODE_GEN_MODEL_ID=deepseek
THESIS_GEN_MODEL_ID=glm

# Per-user token budget (phase-1 free quota control)
DEFAULT_USER_TOKEN_BUDGET=500000
FREE_USER_WORKSPACE_LIMIT=3
CODE_GEN_TOKEN_RESERVE=120000
THESIS_GEN_TOKEN_RESERVE=220000
CHAT_TOKEN_RESERVE=8000
TOKEN_BILLING_MULTIPLIER=3
TOKEN_POINTS_PER_YUAN=1000
DAILY_USER_POINT_LIMIT=500000
DEFAULT_USER_TASK_CONCURRENCY_LIMIT=1
TASK_FAILURE_RETRY_LIMIT=2
SINGLE_TASK_TOKEN_HARD_LIMIT=240000
REFERRAL_REWARD_YUAN=0
ENABLE_CODE_GENERATION=true
ENABLE_THESIS_GENERATION=true
ENABLE_PREVIEW_BUILD=true
REQUIRE_RECHARGE_FOR_DOWNLOAD=true
MAINTENANCE_NOTICE_ENABLED=false
MAINTENANCE_NOTICE_TEXT=
SUPPORT_CONTACT_ENABLED=true
SUPPORT_CONTACT_TITLE=一对一辅导（人工）
SUPPORT_CONTACT_DESCRIPTION=可联系客服获取选题把关、部署排错、答辩材料梳理等一对一支持。
SUPPORT_CONTACT_QR_URL=/support-qr-placeholder.svg

# Optional SMS
# SMS_MODE: mock | real (default: dev=mock, prod=real)
SMS_MODE=mock
SMSBAO_USER=
SMSBAO_API_KEY=
# Backward-compat aliases
SMS_API_USER=
SMS_API_KEY=
SMS_COOLDOWN_SECONDS=60
SMS_PHONE_HOURLY_LIMIT=5
SMS_PHONE_DAILY_LIMIT=10
SMS_IP_MINUTE_LIMIT=20
SMS_IP_DAILY_LIMIT=200
SMS_VERIFY_MAX_ATTEMPTS=8
SMS_VERIFY_LOCK_SECONDS=900

# Optional email verification
# EMAIL_MODE: mock | real (default: dev=mock, prod=real)
EMAIL_MODE=mock
EMAIL_COOLDOWN_SECONDS=60
EMAIL_DAILY_LIMIT=10
EMAIL_HOURLY_LIMIT=5
EMAIL_IP_MINUTE_LIMIT=20
EMAIL_IP_DAILY_LIMIT=200
EMAIL_VERIFY_MAX_ATTEMPTS=8
EMAIL_VERIFY_LOCK_SECONDS=900
EMAIL_CODE_EXPIRE_SECONDS=300
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

# Optional payment
HUPIJIAO_APPID=
HUPIJIAO_SECRET=

# Built-in admin (change before public deployment)
BUILTIN_ADMIN_PHONE=15811410745
BUILTIN_ADMIN_PASSWORD=15811410745
BUILTIN_ADMIN_NAME=系统管理员

# Storage provider (local | oss)
STORAGE_PROVIDER=local

# OSS config (used when STORAGE_PROVIDER=oss)
OSS_REGION=oss-cn-beijing
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# Backward-compat aliases (optional)
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
