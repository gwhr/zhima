# Database
DATABASE_URL=postgresql://zhima:zhima_dev@localhost:5433/zhima

# Redis
REDIS_URL=redis://localhost:6379

# NextAuth
NEXTAUTH_SECRET=your-secret-here-change-in-production
NEXTAUTH_URL=http://localhost:3000
# Optional: dedicated secret for encrypting admin-saved model keys
# If empty, system falls back to NEXTAUTH_SECRET
CONFIG_ENCRYPTION_SECRET=

# Zhipu GLM (required)
ZHIPU_API_KEY=your-zhipu-api-key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Optional AI providers
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Worker fixed model strategy (no frontend model dropdown)
CODE_GEN_MODEL_ID=deepseek
THESIS_GEN_MODEL_ID=glm

# Per-user token budget (phase-1 free quota control)
DEFAULT_USER_TOKEN_BUDGET=500000
CODE_GEN_TOKEN_RESERVE=120000
THESIS_GEN_TOKEN_RESERVE=220000
DEFAULT_USER_TASK_CONCURRENCY_LIMIT=1
TASK_FAILURE_RETRY_LIMIT=2
SINGLE_TASK_TOKEN_HARD_LIMIT=240000
ENABLE_CODE_GENERATION=true
ENABLE_THESIS_GENERATION=true
ENABLE_PREVIEW_BUILD=true
MAINTENANCE_NOTICE_ENABLED=false
MAINTENANCE_NOTICE_TEXT=

# Optional SMS
SMS_API_USER=
SMS_API_KEY=

# Optional payment
HUPIJIAO_APPID=
HUPIJIAO_SECRET=

# Built-in admin (change before public deployment)
BUILTIN_ADMIN_PHONE=15811410745
BUILTIN_ADMIN_PASSWORD=15811410745
BUILTIN_ADMIN_NAME=系统管理员

# Storage provider (local | oss)
STORAGE_PROVIDER=local

# OSS config (used when STORAGE_PROVIDER=oss)
OSS_REGION=oss-cn-beijing
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# Backward-compat aliases (optional)
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
